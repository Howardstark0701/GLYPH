  <!-- ════════════════════════════════════════════════════════
       SCRIPTS
  ═════════════════════════════════════════════════════════ -->
  <script define:vars={{ seedDecisions: decisions }}>
    const API_BASE = (window as any).__GLYPH_API__ ?? (import.meta as any).env?.PUBLIC_API_BASE_URL ?? 'http://localhost:8000';

    // ── Hydrate from real API ─────────────────────────────
    (function hydrateDecisions() {
      const pathParts = window.location.pathname.split('/').filter(Boolean);
      const jobId     = pathParts[1] ?? '';
      const uuidRe    = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
      if (!uuidRe.test(jobId)) return;

      fetch(`${API_BASE}/api/repo/${jobId}/decisions`)
        .then(r => r.ok ? r.json() : null)
        .then(data => {
          if (!data?.decisions?.length) return;

          const list = document.getElementById('timeline-list');
          if (!list) return;
          list.innerHTML = '';

          data.decisions.forEach((d, idx) => {
            const title   = (d.title ?? 'UNKNOWN').toUpperCase().replace(/\s+/g, '_');
            const summary = d.summary ?? '';
            const sha     = (d.source_refs?.[0] ?? '0000000').slice(0, 7);
            const conf    = Math.round((d.confidence ?? 0) * 100);
            const contrib = Array.isArray(d.contributors) ? d.contributors[0] ?? 'unknown' : 'unknown';
            const ts      = (d.timestamp ?? '').replace('T', ' ').replace('Z', '');
            const padIdx  = String(idx + 1).padStart(2, '0');

            const item = document.createElement('div');
            item.className = 'timeline-item';
            item.setAttribute('role', 'listitem');
            item.innerHTML = `
              <div class="tl-dot"></div>
              <div class="decision-card">
                <div class="dc-top">
                  <div class="dc-id-ts">
                    <span class="dc-id">DECISION_${padIdx} // ${ts}</span>
                  </div>
                  <span class="dc-status-chip" style="color:#a1a1a1;border-color:#a1a1a1;">STABLE</span>
                </div>
                <h2 class="dc-title">${title}</h2>
                <p class="dc-summary">${summary}</p>
                <div class="dc-footer">
                  <div class="dc-footer-left">
                    <span class="dc-commit-label">COMMIT:</span>
                    <span class="dc-commit-val">${sha}</span>
                    <span class="dc-conf-label">CONFIDENCE:</span>
                    <span class="dc-conf-val">${conf}%</span>
                  </div>
                  <span class="dc-contributor">@${contrib}</span>
                </div>
              </div>`;
            list.appendChild(item);
          });

          const tot = document.getElementById('stream-total');
          if (tot) tot.textContent = String(data.total ?? data.decisions.length);
        })
        .catch(() => {});
    })();

    // ── Execute fetch ─────────────────────────────────────
    (function() {
      const btn = document.getElementById('execute-fetch');
      if (!btn) return;
      btn.addEventListener('click', () => {
        btn.textContent = 'FETCHING...';
        setTimeout(() => { btn.textContent = 'EXECUTE_FETCH'; }, 2000);
      });
    })();

    // ── Live stream ───────────────────────────────────────
    (function initStream() {
      const body    = document.getElementById('stream-body');
      if (!body) return;

      const decisions = seedDecisions;
      const tags  = ['LOG', 'EVENT', 'SYSTEM', 'LINK', 'CONFIDENCE', 'CONTRIBUTOR'];
      const shas  = ['7f3a9e2','d92c1b0','33ab8f4','a1f042c','5c8b3d1','e74f901'];
      const handles = ['arch_priya','lead_author','dev_soren','infra_tolly','sec_ananya'];
      let di = 0, si = 0, hi = 0, decNum = decisions.length + 1;

      function nowTs() {
        const d = new Date();
        return `[${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}:${String(d.getSeconds()).padStart(2,'0')}]`;
      }

      const generators = [
        () => `<span class="s-ts">${nowTs()}</span><span class="s-tag"> [INDEX] </span><span class="s-em">DECISION_${String(decNum++).padStart(2,'0')}</span><span class="s-tag"> written to ledger</span>`,
        () => `<span class="s-ts">${nowTs()}</span><span class="s-tag"> [LINK] </span><span class="s-tag">commit </span><span class="s-red">${shas[si++ % shas.length]}</span><span class="s-tag"> → DECISION_${String(decNum - 1).padStart(2,'0')}</span>`,
        () => `<span class="s-ts">${nowTs()}</span><span class="s-tag"> [CONFIDENCE] </span><span class="s-tag">score </span><span class="s-em">${Math.floor(Math.random()*30+70)}%</span><span class="s-tag"> assigned</span>`,
        () => `<span class="s-ts">${nowTs()}</span><span class="s-tag"> [CONTRIBUTOR] </span><span class="s-em">@${handles[hi++ % handles.length]}</span><span class="s-tag"> flagged as author</span>`,
        () => `<span class="s-ts">${nowTs()}</span><span class="s-tag"> [NEW_DECISION_PENDING] </span><span class="s-tag">Caching strategy for /v${Math.floor(Math.random()*3+1)}/nodes</span>`,
        () => `<span class="s-ts">${nowTs()}</span><span class="s-tag"> [SYSTEM] </span><span class="s-tag">ANALYZING IMPACT on EXISTING_DATA_STRUCTURES...</span>`,
      ];

      let gIdx = 0;
      setInterval(() => {
        const line = document.createElement('div');
        line.className = 's-line';
        line.innerHTML = generators[gIdx % generators.length]();
        gIdx++;
        body.appendChild(line);
        body.scrollTop = body.scrollHeight;
        while (body.children.length > 40) body.removeChild(body.firstChild);
      }, 2000);
    })();
  </script>

</body>
