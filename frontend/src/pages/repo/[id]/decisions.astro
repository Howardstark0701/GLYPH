              <span class="stream-live-sq" aria-hidden="true"></span>
              DECISION_STREAM
              <span class="stream-sep">//</span>
              INDEXED
            </div>
            <span class="stream-header-right">TOTAL: <span id="stream-total">{decisions.length}</span></span>
          </div>
          <div id="stream-body" role="log" aria-label="Decision stream" aria-live="polite">
            {decisions.slice(0, 5).map((d) => (
              <div class="s-line">
                <span class="s-ts">[LOG]</span>
                <span class="s-tag"> PARSING </span>
                <span class="s-em">DECISION_{String(d.index).padStart(2,'0')}: {d.title}</span>
                <span class="s-tag"> ({d.sha})</span>
              </div>
            ))}
            <div class="s-line"><span class="s-ts">[LISTENING]</span><span class="s-tag"> AWAITING REAL-TIME ARCHITECTURAL EVENTS...</span></div>
          </div>
        </section>

      </div><!-- /content-body -->
    </div><!-- /main-area -->
