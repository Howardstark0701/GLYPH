---
// GLYPH OS — Chronological Decision Index
// src/pages/repo/[id]/decisions.astro
export const prerender = false;

const { id } = Astro.params;

let repoOwner = 'unknown';
let repoName  = 'unknown';
try {
  const decoded = decodeURIComponent(id ?? '');
  const match   = decoded.match(/github\.com\/([^\/]+)\/([^\/\s]+)/);
  if (match) {
    repoOwner = match[1];
    repoName  = match[2].replace(/\.git$/, '');
  } else {
    const parts = decoded.split('/').filter(Boolean);
    if (parts.length >= 2) { repoOwner = parts[0]; repoName = parts[1]; }
    else if (parts.length === 1) { repoName = parts[0]; }
  }
} catch (_) {}

// ── Static seed data (replaced by API in prod) ────────────
interface Decision {
  index:       number;
  title:       string;
  summary:     string;
  sha:         string;
  confidence:  number;
  contributor: string;
  timestamp:   string;
  status:      'STABLE' | 'CRITICAL' | 'RESOLVED';
}

const decisions: Decision[] = [
  { index:1,  title:'INIT_REPO_STRUCTURE',       summary:'Established core monorepo architecture leveraging workspace-level abstractions. Prioritizing modular hermeticity and build-time efficiency.',                                  sha:'7f3a9e2', confidence:98, contributor:'arch_priya',   timestamp:'2024-02-09T11:02Z', status:'STABLE'   },
  { index:2,  title:'ADOPT_AXUM_FRAMEWORK',       summary:'Migration from prototype Tower service to full Axum stack for ergonomic routing and type-safe state management. High throughput baseline achieved.',                           sha:'d92c1b0', confidence:92, contributor:'lead_author',  timestamp:'2024-02-21T16:30Z', status:'CRITICAL'  },
  { index:3,  title:'POSTGRESQL_OVER_SQLITE',     summary:'Relational data model mandates ACID guarantees at scale. SQLite ruled out after stress tests revealed lock contention at 500 concurrent analysis jobs.',                       sha:'33ab8f4', confidence:88, contributor:'dev_soren',    timestamp:'2024-03-04T09:17Z', status:'STABLE'   },
  { index:4,  title:'ASYNC_RUNTIME_TOKIO',        summary:'Tokio selected over async-std following benchmark suite showing 22% lower tail latency on GitHub API ingestion workloads with full feature set.',                              sha:'a1f042c', confidence:95, contributor:'arch_priya',   timestamp:'2024-03-14T14:55Z', status:'STABLE'   },
  { index:5,  title:'BYOK_CREDENTIAL_MODEL',      summary:'No server-side key storage. All GitHub PAT and NIM API keys travel as per-request headers, discarded after use. Eliminates entire secret-management attack surface.',          sha:'5c8b3d1', confidence:99, contributor:'sec_ananya',   timestamp:'2024-03-28T10:22Z', status:'STABLE'   },
  { index:6,  title:'NVIDIA_NIM_INTEGRATION',     summary:'Structured JSON prompting via llama-3.1-nemotron-70b. Temperature 0.1 for deterministic extraction. Markdown fence stripping required due to model output formatting.',       sha:'e74f901', confidence:81, contributor:'lead_author',  timestamp:'2024-04-08T13:40Z', status:'CRITICAL'  },
  { index:7,  title:'SHUTTLE_DEPLOYMENT_CHOICE',  summary:'Shuttle.rs selected for zero-config Rust deployment. Shared PostgreSQL provisioning removes infrastructure overhead. Trade-off: limited egress control accepted.',             sha:'2b6d5a7', confidence:76, contributor:'infra_tolly',  timestamp:'2024-04-19T08:11Z', status:'STABLE'   },
  { index:8,  title:'SQLX_OVER_DIESEL',           summary:'SQLx chosen for compile-time verified queries without ORM overhead. Diesel macro complexity deemed unsuitable for rapid schema iteration at current phase.',                   sha:'9f1c3e8', confidence:90, contributor:'dev_soren',    timestamp:'2024-05-02T15:33Z', status:'STABLE'   },
  { index:9,  title:'REQWEST_HTTP_CLIENT',        summary:'reqwest 0.12 with JSON feature selected for GitHub and NIM API calls. Connection pooling via Client::new() shared across AppState. Timeout set to 30s.',                      sha:'4a7b2f0', confidence:85, contributor:'arch_priya',   timestamp:'2024-05-17T11:09Z', status:'STABLE'   },
  { index:10, title:'PAGINATION_STRATEGY',        summary:'Hard cap at 10 pages × 100 items per ingestion call. Prevents runaway rate-limit exhaustion on large repos. Configurable per-repo override planned for v2.',                  sha:'c3d9e61', confidence:78, contributor:'lead_author',  timestamp:'2024-06-01T09:44Z', status:'RESOLVED' },
  { index:11, title:'ERROR_HANDLING_PATTERN',     summary:'Unified AppError enum implementing IntoResponse for Axum. All variant arms map to deterministic HTTP status codes. No panic paths in production handlers.',                   sha:'7e4a8b3', confidence:94, contributor:'dev_soren',    timestamp:'2024-06-18T14:27Z', status:'STABLE'   },
  { index:12, title:'CORS_MIDDLEWARE_ADDED',      summary:'tower-http CorsLayer configured to allow Vercel and localhost:4321 origins. All methods permitted. Headers: Any. Deployed before frontend integration phase.',               sha:'1d5f7c9', confidence:88, contributor:'infra_tolly',  timestamp:'2024-07-04T10:15Z', status:'STABLE'   },
];

const stats = {
  total:        decisions.length,
  avgConf:      Math.round(decisions.reduce((a, d) => a + d.confidence, 0) / decisions.length),
  contributors: [...new Set(decisions.map(d => d.contributor))].length,
  timeSpanDays: 214,
};

const confBuckets = [
  { label: 'HIGH (90%+)',    pct: Math.round(decisions.filter(d => d.confidence >= 90).length / decisions.length * 100) },
  { label: 'MED (70–89%)',   pct: Math.round(decisions.filter(d => d.confidence >= 70 && d.confidence < 90).length / decisions.length * 100) },
  { label: 'LOW (50–69%)',   pct: Math.round(decisions.filter(d => d.confidence >= 50 && d.confidence < 70).length / decisions.length * 100) },
  { label: 'MINIMAL (<50%)', pct: Math.round(decisions.filter(d => d.confidence < 50).length / decisions.length * 100) },
];

const topMakers = Object.entries(
  decisions.reduce((acc, d) => {
    acc[d.contributor] = (acc[d.contributor] ?? 0) + 1;
    return acc;
  }, {} as Record<string, number>)
)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 3)
  .map(([handle, count]) => ({ handle, count, pct: Math.round(count / decisions.length * 100) }));

const statusColor = (s: Decision['status']) =>
  s === 'CRITICAL' ? '#cc0000' : s === 'RESOLVED' ? '#5e3f3a' : '#a1a1a1';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>GLYPH — Decision Index — {repoOwner}/{repoName}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&family=Karla:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    /* ── Reset ───────────────────────────────────────────── */
    *, *::before, *::after {
      box-sizing: border-box;
      border-radius: 0 !important;
      box-shadow: none !important;
      text-shadow: none !important;
      transition: none !important;
      outline: none;
    }
    html, body {
      margin: 0; padding: 0;
      background: #131313;
      color: #e5e2e1;
      font-family: 'Karla', sans-serif;
      height: 100%;
      overflow: hidden;
    }

    /* ── Type helpers ─────────────────────────────────────── */
    .mono      { font-family: 'JetBrains Mono', monospace; }
    .display   { font-family: 'Space Grotesk', sans-serif; }
    .data-sm   { font-family: 'JetBrains Mono', monospace; font-size: 0.6875rem; line-height: 1.2; }
    .label-caps{ font-family: 'JetBrains Mono', monospace; font-size: 0.625rem; letter-spacing: 0.1em; text-transform: uppercase; line-height: 1; }

    /* ══════════════════════════════════════════════════════
       NAVBAR — 44px fixed
    ══════════════════════════════════════════════════════ */
    #navbar {
      position: fixed; top: 0; left: 0; right: 0; height: 44px;
      background: #131313;
      border-bottom: 1px solid #262626;
      display: grid;
      grid-template-columns: 160px 1fr auto;
      align-items: center;
      z-index: 200;
    }
    #nav-brand {
      padding: 0 14px;
      display: flex; flex-direction: column; gap: 2px;
      border-right: 1px solid #262626; height: 100%; justify-content: center;
    }
    #nav-brand a {
      font-family: 'Space Grotesk', sans-serif; font-weight: 700;
      font-size: 0.875rem; color: #ffb4a8; text-decoration: none;
      letter-spacing: -0.01em; line-height: 1;
    }
    #nav-brand .sub {
      font-family: 'JetBrains Mono', monospace; font-size: 0.55rem;
      color: #a1a1a1; letter-spacing: 0.06em; text-transform: uppercase;
    }
    #nav-title {
      padding: 0 18px;
      font-family: 'Space Grotesk', sans-serif; font-weight: 700;
      font-size: 1rem; color: #e5e2e1; letter-spacing: 0.02em;
    }
    #nav-icons { display: flex; align-items: center; gap: 8px; padding-right: 16px; }
    .nav-icon-btn {
      width: 28px; height: 28px; background: transparent;
      border: 1px solid #262626; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      color: #a1a1a1; padding: 0;
    }
    .nav-icon-btn:hover { border-color: #cc0000; color: #cc0000; }

    /* ══════════════════════════════════════════════════════
       LAYOUT
    ══════════════════════════════════════════════════════ */
    #layout {
      position: fixed; top: 44px; left: 0; right: 0; bottom: 0;
      display: flex;
    }

    /* ══════════════════════════════════════════════════════
       LEFT SIDEBAR — 160px
    ══════════════════════════════════════════════════════ */
    #sidebar {
      width: 160px; flex-shrink: 0;
      background: #131313; border-right: 1px solid #262626;
      display: flex; flex-direction: column; overflow: hidden;
    }
    .sidebar-nav { flex: 1; display: flex; flex-direction: column; padding-top: 6px; }
    .nav-item {
      display: flex; align-items: center; gap: 9px; padding: 9px 14px;
      font-family: 'JetBrains Mono', monospace; font-size: 0.6rem;
      letter-spacing: 0.12em; text-transform: uppercase;
      color: #a1a1a1; cursor: pointer; user-select: none;
      border: none; border-left: 2px solid transparent;
      background: transparent; width: 100%; text-align: left; text-decoration: none;
    }
    .nav-item:hover:not(.active) { color: #e5e2e1; background: #1a1a1a; }
    .nav-item.active { border-left-color: #cc0000; color: #ffffff; background: transparent; }
    .sidebar-spacer { flex: 1; }
    .nav-item-logout { border-top: 1px solid #262626; color: #5e3f3a; }
    .nav-item-logout:hover { color: #cc0000; background: transparent; }
    .sidebar-footer { border-top: 1px solid #262626; padding: 10px; display: flex; flex-direction: column; gap: 8px; }
    #execute-fetch {
      width: 100%; background: #cc0000; border: none;
      font-family: 'JetBrains Mono', monospace; font-size: 0.6rem;
      letter-spacing: 0.12em; text-transform: uppercase;
      color: #fff; padding: 8px 0; cursor: pointer; text-align: center;
    }
    #execute-fetch:hover { background: #ff0000; }
    .util-row { display: flex; gap: 6px; }
    .util-btn {
      flex: 1; display: flex; align-items: center; gap: 5px;
      background: transparent; border: 1px solid #262626;
      color: #a1a1a1; font-family: 'JetBrains Mono', monospace;
      font-size: 0.55rem; letter-spacing: 0.1em; text-transform: uppercase;
      padding: 5px 6px; cursor: pointer; text-decoration: none;
    }
    .util-btn:hover { border-color: #cc0000; color: #cc0000; }

    /* ══════════════════════════════════════════════════════
       MAIN AREA
    ══════════════════════════════════════════════════════ */
    #main-area {
      flex: 1; display: flex; flex-direction: column;
      overflow: hidden; min-width: 0;
    }

    /* ── Page header ──────────────────────────────────────── */
    #page-header {
      padding: 16px 20px 14px; border-bottom: 1px solid #262626; flex-shrink: 0;
    }
    .breadcrumb-row {
      display: flex; align-items: center; gap: 8px; margin-bottom: 6px;
    }
    .bc-label { font-family:'JetBrains Mono',monospace; font-size:0.6rem; letter-spacing:0.12em; text-transform:uppercase; color:#cc0000; }
    .bc-sep   { color: #3a3a3a; }
    .bc-status{ font-family:'JetBrains Mono',monospace; font-size:0.6rem; letter-spacing:0.12em; text-transform:uppercase; color:#a1a1a1; }
    .page-title {
      font-family: 'Space Grotesk', sans-serif; font-weight: 700;
      font-size: 1.9rem; color: #ffb4a8; line-height: 1; margin: 0 0 8px;
      letter-spacing: -0.01em;
    }
    .page-desc { font-family:'Karla',sans-serif; font-size:0.875rem; color:#a1a1a1; line-height:1.5; margin:0; max-width:680px; }

    /* ── Content body ─────────────────────────────────────── */
    #content-body {
      flex: 1; display: grid;
      grid-template-columns: 1fr 260px;
      grid-template-rows: 1fr 140px;
      overflow: hidden; min-height: 0;
    }

    /* ══════════════════════════════════════════════════════
       TIMELINE COLUMN — scrollable
    ══════════════════════════════════════════════════════ */
    #timeline-col {
      grid-column: 1; grid-row: 1;
      border-right: 1px solid #262626;
      overflow-y: auto; padding: 20px 24px 20px 20px;
      position: relative;
    }
    #timeline-col::-webkit-scrollbar { width: 3px; }
    #timeline-col::-webkit-scrollbar-track { background: #131313; }
    #timeline-col::-webkit-scrollbar-thumb { background: #262626; }

    /* Vertical timeline spine */
    .timeline-spine {
      position: absolute; left: 36px; top: 20px; bottom: 20px;
      width: 1px; background: #cc0000;
    }

    .timeline-item {
      position: relative; display: flex; align-items: flex-start;
      gap: 16px; margin-bottom: 28px;
    }
    .timeline-item:last-child { margin-bottom: 0; }

    /* Square dot on the spine */
    .tl-dot {
      width: 8px; height: 8px; background: #cc0000;
      flex-shrink: 0; margin-top: 14px; position: relative; z-index: 1;
    }

    /* Decision card */
    .decision-card {
      flex: 1; background: #0e0e0e; border: 1px solid #262626;
      padding: 0; overflow: hidden;
    }

    .dc-top {
      display: flex; align-items: center; justify-content: space-between;
      padding: 8px 12px 6px;
    }
    .dc-id-ts {
      display: flex; align-items: center; gap: 10px;
    }
    .dc-id {
      font-family:'JetBrains Mono',monospace; font-size:0.55rem;
      letter-spacing:0.1em; text-transform:uppercase; color:#cc0000;
    }
    .dc-ts {
      font-family:'JetBrains Mono',monospace; font-size:0.55rem;
      color:#5e3f3a; letter-spacing:0.04em;
    }
    .dc-status-chip {
      font-family:'JetBrains Mono',monospace; font-size:0.5rem;
      letter-spacing:0.1em; text-transform:uppercase;
      border: 1px solid; padding: 2px 6px; line-height: 1;
      background: transparent;
    }

    .dc-title {
      font-family:'Space Grotesk',sans-serif; font-weight:600;
      font-size:0.9rem; color:#e5e2e1; text-transform:uppercase;
      letter-spacing:0.01em; padding: 0 12px 6px; line-height: 1.2; margin: 0;
    }

    .dc-summary {
      font-family:'Karla',sans-serif; font-size:0.8125rem; color:#a1a1a1;
      line-height:1.45; padding: 0 12px 10px;
      display: -webkit-box; -webkit-line-clamp: 2;
      -webkit-box-orient: vertical; overflow: hidden;
    }

    .dc-footer {
      display: flex; align-items: center; justify-content: space-between;
      padding: 7px 12px; border-top: 1px solid #262626;
    }
    .dc-footer-left { display: flex; align-items: center; gap: 12px; }
    .dc-commit-label { font-family:'JetBrains Mono',monospace; font-size:0.55rem; letter-spacing:0.1em; text-transform:uppercase; color:#a1a1a1; }
    .dc-commit-val   { font-family:'JetBrains Mono',monospace; font-size:0.6rem; color:#cc0000; }
    .dc-conf-label   { font-family:'JetBrains Mono',monospace; font-size:0.55rem; letter-spacing:0.1em; text-transform:uppercase; color:#a1a1a1; }
    .dc-conf-val     { font-family:'JetBrains Mono',monospace; font-size:0.6rem; color:#e5e2e1; }
    .dc-contributor  { font-family:'JetBrains Mono',monospace; font-size:0.6rem; color:#5e3f3a; }

    /* ══════════════════════════════════════════════════════
       INTELLIGENCE SIDEBAR — right col
    ══════════════════════════════════════════════════════ */
    #intel-sidebar {
      grid-column: 2; grid-row: 1;
      border-bottom: 1px solid #262626;
      background: #131313; overflow-y: auto;
      display: flex; flex-direction: column;
    }
    #intel-sidebar::-webkit-scrollbar { width: 3px; }
    #intel-sidebar::-webkit-scrollbar-track { background: #131313; }
    #intel-sidebar::-webkit-scrollbar-thumb { background: #262626; }

    .intel-section {
      padding: 12px 14px; border-bottom: 1px solid #262626;
    }
    .intel-section:last-child { border-bottom: none; }
    .intel-section-label {
      font-family:'JetBrains Mono',monospace; font-size:0.6rem;
      letter-spacing:0.12em; text-transform:uppercase; color:#cc0000;
      display:block; margin-bottom:10px;
    }

    /* Stats grid — 2×2 */
    .stats-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 12px 8px;
    }
    .stat-cell {}
    .stat-cell-label {
      font-family:'JetBrains Mono',monospace; font-size:0.55rem;
      letter-spacing:0.1em; text-transform:uppercase; color:#a1a1a1;
      display:block; margin-bottom:3px;
    }
    .stat-cell-value {
      font-family:'JetBrains Mono',monospace; font-weight:700;
      font-size:1.3rem; color:#e5e2e1; line-height:1;
    }
    .stat-cell-value.accent { color: #e5e2e1; }

    /* Confidence distribution bars */
    .conf-bar-row {
      display: flex; align-items: center; gap: 8px;
      margin-bottom: 7px;
    }
    .conf-bar-row:last-child { margin-bottom: 0; }
    .conf-bar-label {
      font-family:'JetBrains Mono',monospace; font-size:0.55rem;
      letter-spacing:0.06em; text-transform:uppercase; color:#a1a1a1;
      width: 86px; flex-shrink: 0;
    }
    .conf-bar-track {
      flex: 1; height: 3px; background: #1a1a1a; position: relative;
    }
    .conf-bar-fill { height: 3px; background: #cc0000; }
    .conf-bar-pct {
      font-family:'JetBrains Mono',monospace; font-size:0.55rem;
      color:#cc0000; width: 28px; text-align:right; flex-shrink:0;
    }

    /* Top makers */
    .maker-row { margin-bottom: 9px; }
    .maker-row:last-child { margin-bottom: 0; }
    .maker-header {
      display: flex; justify-content: space-between; align-items: center;
      margin-bottom: 4px;
    }
    .maker-handle {
      font-family:'JetBrains Mono',monospace; font-weight:600;
      font-size:0.65rem; color:#e5e2e1;
    }
    .maker-count {
      font-family:'JetBrains Mono',monospace; font-size:0.6rem; color:#a1a1a1;
    }
    .maker-bar-track { width:100%; height:1px; background:#262626; position:relative; }
    .maker-bar-fill  { height:1px; background:#cc0000; }

    /* ══════════════════════════════════════════════════════
       BOTTOM STREAM PANEL
    ══════════════════════════════════════════════════════ */
    #stream-panel {
      grid-column: 1 / 3; grid-row: 2;
      background: #0e0e0e; border-top: 1px solid #262626;
      display: flex; flex-direction: column; overflow: hidden;
    }
    #stream-header {
      padding: 6px 14px; border-bottom: 1px solid #262626;
      background: #131313; flex-shrink: 0;
      display: flex; align-items: center; justify-content: space-between;
    }
    .stream-header-left {
      display: flex; align-items: center; gap: 8px;
      font-family:'JetBrains Mono',monospace; font-size:0.6rem;
      letter-spacing:0.1em; text-transform:uppercase; color:#e5e2e1;
    }
    .stream-live-sq { width:7px; height:7px; background:#cc0000; flex-shrink:0; }
    .stream-sep { color:#5e3f3a; margin: 0 2px; }
    .stream-header-right {
      font-family:'JetBrains Mono',monospace; font-size:0.6rem;
      letter-spacing:0.06em; color:#a1a1a1;
    }
    #stream-body {
      flex: 1; overflow-y: auto; padding: 6px 14px;
      display: flex; flex-direction: column; gap: 0;
    }
    #stream-body::-webkit-scrollbar { width: 3px; }
    #stream-body::-webkit-scrollbar-track { background: #0e0e0e; }
    #stream-body::-webkit-scrollbar-thumb { background: #262626; }
    .s-line {
      font-family:'JetBrains Mono',monospace; font-size:0.6rem;
      line-height:1.6; white-space:nowrap; color:#a1a1a1; letter-spacing:0.04em;
    }
    .s-ts   { color: #5e3f3a; }
    .s-tag  { color: #a1a1a1; }
    .s-em   { color: #e5e2e1; }
    .s-red  { color: #cc0000; }
  </style>
</head>
<body>

  <!-- ════════════════════════════════════════════════════════
       NAVBAR
  ═════════════════════════════════════════════════════════ -->
  <nav id="navbar" aria-label="System navigation">
    <div id="nav-brand">
      <a href="/" aria-label="Return to GLYPH home">GLYPH_OS</a>
      <span class="sub">SYSTEM_OPERATOR</span>
    </div>
    <div id="nav-title">GLYPH_OS &nbsp;<span style="font-size:0.75rem;font-weight:400;color:#a1a1a1;letter-spacing:0.06em;">v4.0.2-STABLE</span></div>
    <div id="nav-icons">
      <!-- Clock -->
      <button class="nav-icon-btn" aria-label="Clock" title="Clock">
        <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
          <circle cx="6.5" cy="6.5" r="5.5" stroke="currentColor" stroke-width="1"/>
          <line x1="6.5" y1="3" x2="6.5" y2="6.5" stroke="currentColor" stroke-width="1"/>
          <line x1="6.5" y1="6.5" x2="9" y2="8" stroke="currentColor" stroke-width="1"/>
        </svg>
      </button>
      <!-- Snowflake / network -->
      <button class="nav-icon-btn" aria-label="Network" title="Network">
        <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
          <line x1="6.5" y1="1" x2="6.5" y2="12" stroke="currentColor" stroke-width="1"/>
          <line x1="1" y1="6.5" x2="12" y2="6.5" stroke="currentColor" stroke-width="1"/>
          <line x1="2.5" y1="2.5" x2="10.5" y2="10.5" stroke="currentColor" stroke-width="1"/>
          <line x1="10.5" y1="2.5" x2="2.5" y2="10.5" stroke="currentColor" stroke-width="1"/>
        </svg>
      </button>
      <!-- Settings -->
      <button class="nav-icon-btn" aria-label="Settings" title="Settings">
        <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
