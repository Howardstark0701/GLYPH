    <!-- ── MAIN AREA ──────────────────────────────────────── -->
    <div id="main-area">

      <!-- Page header -->
      <header id="page-header">
        <div class="breadcrumb-row">
          <span class="bc-label">DECISION_LEDGER</span>
          <span class="bc-sep">/</span>
          <span class="bc-status">STATUS: INDEXED</span>
        </div>
        <h1 class="page-title">CHRONOLOGICAL DECISION INDEX</h1>
        <p class="page-desc">
          Architectural lineage extracted from high-fidelity commit history and neural-link developer logs.
          Validating system evolution through structural shifts and dependency resolutions.
        </p>
      </header>

      <!-- Content -->
      <div id="content-body">

        <!-- ── TIMELINE ──────────────────────────────────── -->
        <section id="timeline-col" aria-label="Decision timeline">
          <!-- Vertical spine -->
          <div class="timeline-spine" aria-hidden="true"></div>

          <div id="timeline-list" role="list" aria-label="Architectural decisions">
            {decisions.map((d) => (
              <div class="timeline-item" role="listitem" aria-label={`Decision: ${d.title}`}>
                <div class="tl-dot" aria-hidden="true"></div>
                <div class="decision-card">
                  <div class="dc-top">
                    <div class="dc-id-ts">
                      <span class="dc-id">DECISION_{String(d.index).padStart(2,'0')} // {d.timestamp.replace('T',' ').replace('Z','')}</span>
                    </div>
                    <span
                      class="dc-status-chip"
                      style={`color:${statusColor(d.status)};border-color:${statusColor(d.status)};`}
                    >{d.status}</span>
                  </div>
                  <h2 class="dc-title">{d.title}</h2>
                  <p class="dc-summary">{d.summary}</p>
                  <div class="dc-footer">
                    <div class="dc-footer-left">
                      <span class="dc-commit-label">COMMIT:</span>
                      <span class="dc-commit-val">{d.sha}</span>
                      <span class="dc-conf-label">CONFIDENCE:</span>
                      <span class="dc-conf-val">{d.confidence}%</span>
                    </div>
                    <span class="dc-contributor">@{d.contributor}</span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- ── INTELLIGENCE SIDEBAR ──────────────────────── -->
        <aside id="intel-sidebar" aria-label="Decision intelligence">

          <!-- Stats -->
          <div class="intel-section">
            <span class="intel-section-label">DECISION_STATS</span>
            <div class="stats-grid">
              <div class="stat-cell" aria-label={`Total decisions: ${stats.total}`}>
                <span class="stat-cell-label">TOTAL</span>
                <span class="stat-cell-value">{stats.total}</span>
              </div>
              <div class="stat-cell" aria-label={`Average confidence: ${stats.avgConf}%`}>
                <span class="stat-cell-label">AVG CONFIDENCE</span>
                <span class="stat-cell-value">{stats.avgConf}%</span>
              </div>
              <div class="stat-cell" aria-label={`Contributors: ${stats.contributors}`}>
                <span class="stat-cell-label">CONTRIBUTORS</span>
                <span class="stat-cell-value">{stats.contributors}</span>
              </div>
              <div class="stat-cell" aria-label={`Time span: ${stats.timeSpanDays} days`}>
                <span class="stat-cell-label">TIME SPAN</span>
                <span class="stat-cell-value" style="font-size:1rem;">{stats.timeSpanDays} <span style="font-size:0.75rem;font-weight:400;">days</span></span>
              </div>
