          </div>

          <!-- Confidence distribution -->
          <div class="intel-section">
            <span class="intel-section-label">CONFIDENCE_DISTRIBUTION</span>
            {confBuckets.map((b) => (
              <div class="conf-bar-row" aria-label={`${b.label}: ${b.pct}%`}>
                <span class="conf-bar-label">{b.label}</span>
                <div class="conf-bar-track" aria-hidden="true">
                  <div class="conf-bar-fill" style={`width:${b.pct}%`}></div>
                </div>
                <span class="conf-bar-pct">{b.pct}%</span>
              </div>
            ))}
          </div>

          <!-- Top decision makers -->
          <div class="intel-section">
            <span class="intel-section-label">TOP_DECISION_MAKERS</span>
            {topMakers.map((m) => (
              <div class="maker-row" aria-label={`${m.handle}: ${m.count} decisions`}>
                <div class="maker-header">
                  <span class="maker-handle">@{m.handle}</span>
                  <span class="maker-count">{m.count} decisions</span>
                </div>
                <div class="maker-bar-track" aria-hidden="true">
                  <div class="maker-bar-fill" style={`width:${m.pct}%`}></div>
                </div>
              </div>
