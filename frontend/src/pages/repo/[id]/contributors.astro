  <!-- ════════════════════════════════════════════════════════
       SCRIPTS
  ═════════════════════════════════════════════════════════ -->
  <script define:vars={{ seedContributors: contributors }}>
    const API_BASE = (window as any).__GLYPH_API__ ?? (import.meta as any).env?.PUBLIC_API_BASE_URL ?? 'http://localhost:8000';

    // ── Hydrate from real API ─────────────────────────────
    (function hydrateContributors() {
      const pathParts = window.location.pathname.split('/').filter(Boolean);
      const jobId     = pathParts[1] ?? '';
      const uuidRe    = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
      if (!uuidRe.test(jobId)) return;

      fetch(`${API_BASE}/api/repo/${jobId}/contributors`)
        .then(r => r.ok ? r.json() : null)
        .then(data => {
          if (!data?.contributors?.length) return;
          // Update influence histogram bars with real data
          // (full re-render reserved for v2 — API shapes match seed)
        })
        .catch(() => {});
    })();

    // ── Execute fetch ─────────────────────────────────────
    (function() {
      const btns = [
        document.getElementById('feed-exec-btn'),
      ];
      btns.forEach(btn => {
        if (!btn) return;
        btn.addEventListener('click', () => {
          btn.textContent = 'FETCHING...';
          setTimeout(() => { btn.textContent = 'EXECUTE_FETCH'; }, 2000);
        });
      });
    })();

    // ── Live feed ─────────────────────────────────────────
    (function initFeed() {
      const body = document.getElementById('feed-body');
      if (!body) return;

      const cs      = seedContributors;
      const handles = cs.map(c => c.handle);
      const patterns= cs.map(c => c.pattern);
      let   hi = 0, pi = 0, di = 1, ri = 1, pri = 9821;

      function ts() {
        const d = new Date();
        return `${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}:${String(d.getSeconds()).padStart(2,'0')}`;
      }

      const pool = [
        () => `<span class="f-tag">[PROFILE]</span><span class="f-rust"> @${handles[hi++ % handles.length]}</span><span class="f-mute"> — reasoning profile extracted</span>`,
        () => `<span class="f-mute">[INFLUENCE] </span><span class="f-em">@${handles[hi % handles.length]}</span><span class="f-mute"> scored </span><span class="f-em">${Math.floor(Math.random()*50+30)}%</span><span class="f-mute"> influence</span>`,
        () => `<span class="f-mute">[PATTERN] DOMINANT_PATTERN: </span><span class="f-em">${patterns[pi++ % patterns.length]}</span><span class="f-mute"> assigned to </span><span class="f-rust">@${handles[hi % handles.length]}</span>`,
        () => `<span class="f-mute">[DECISION] </span><span class="f-em">@${handles[hi % handles.length]}</span><span class="f-mute"> authored DECISION_${String(di++).padStart(2,'0')}</span>`,
        () => `<span class="f-mute">[DEBATE] </span><span class="f-em">@${handles[hi % handles.length]}</span><span class="f-mute"> opened debate thread PR #${pri++}</span>`,
        () => `<span class="f-mute">[REJECTION] </span><span class="f-em">@${handles[hi % handles.length]}</span><span class="f-mute"> owns REJECTION_RECORD_${String(ri++).padStart(2,'0')}</span>`,
        () => `<span class="f-mute">[MATCH] Heuristic overlap found between </span><span class="f-em">@${handles[0]}</span><span class="f-mute"> and </span><span class="f-em">@${handles[2]}</span>`,
        () => `<span class="f-mute">[QUERY] Fetching authorship weight for PR-${pri}...</span>`,
        () => `<span class="f-mute">[DECRYPT] Reasoning hashes validated for </span><span class="f-em">@${handles[hi % handles.length]}</span>`,
      ];

      let idx = 0;
      setInterval(() => {
        const line = document.createElement('div');
        line.className = 'f-line';
        line.innerHTML = pool[idx % pool.length]();
        idx++;
        body.appendChild(line);
        body.scrollTop = body.scrollHeight;
        while (body.children.length > 40) body.removeChild(body.firstChild);
      }, 2000);
    })();
  </script>

