<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>GLYPH — Intelligence Summary — {repoSlug}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&family=Karla:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    /* ── Reset ───────────────────────────────────────────── */
    *, *::before, *::after {
      box-sizing: border-box;
      border-radius: 0 !important;
      box-shadow: none !important;
      text-shadow: none !important;
      transition: none !important;
      outline: none;
    }
    html, body {
      margin: 0; padding: 0;
      background: #131313;
      color: #e5e2e1;
      font-family: 'Karla', sans-serif;
      height: 100%; overflow: hidden;
      -webkit-font-smoothing: antialiased;
    }

    /* ── Type ─────────────────────────────────────────────── */
    .data-sm    { font-family:'JetBrains Mono',monospace; font-size:0.6875rem; line-height:1.2; }
    .label-caps { font-family:'JetBrains Mono',monospace; font-size:0.625rem; letter-spacing:0.1em; text-transform:uppercase; line-height:1; }

    /* ══════════════════════════════════════════════════════
       NAVBAR — 44px
    ══════════════════════════════════════════════════════ */
    #navbar {
      position: fixed; top:0; left:0; right:0; height:44px;
      background:#131313; border-bottom:1px solid #1a1a1a;
      display:grid; grid-template-columns:160px 1fr auto auto;
      align-items:center; z-index:200;
    }
    #nav-brand {
      padding:0 14px; display:flex; align-items:center;
      border-right:1px solid #1a1a1a; height:100%;
    }
    #nav-brand a {
      font-family:'Space Grotesk',sans-serif; font-weight:700;
      font-size:1rem; color:#ffb4a8; text-decoration:none; letter-spacing:-0.01em;
    }
    #nav-brand .ver {
      font-family:'JetBrains Mono',monospace; font-size:0.55rem;
      color:#cc0000; letter-spacing:0.06em; margin-left:8px;
      border:1px solid #cc0000; padding:1px 5px;
    }
    /* Search */
    #nav-search {
      display:flex; align-items:center;
      border:1px solid #1a1a1a; height:28px; margin:0 20px;
      max-width:440px;
    }
    #nav-search svg { margin:0 8px; flex-shrink:0; color:#3a3a3a; }
    #nav-search input {
      flex:1; background:transparent; border:none;
      font-family:'JetBrains Mono',monospace; font-size:0.6rem;
      color:#e5e2e1; letter-spacing:0.06em; padding-right:8px;
    }
    #nav-search input::placeholder { color:#3a3a3a; }
    /* Right icons */
    #nav-icons { display:flex; align-items:center; gap:6px; padding:0 8px; }
    .nav-icon-btn {
      width:28px; height:28px; background:transparent;
      border:1px solid #1a1a1a; cursor:pointer;
      display:flex; align-items:center; justify-content:center;
      color:#a1a1a1; padding:0;
    }
    .nav-icon-btn:hover { border-color:#cc0000; color:#cc0000; }
    /* User chip */
    #nav-user {
      display:flex; align-items:center; gap:8px;
      padding:0 14px; border-left:1px solid #1a1a1a; height:100%;
    }
    .nav-user-label {
      font-family:'JetBrains Mono',monospace; font-size:0.55rem;
      letter-spacing:0.06em; text-transform:uppercase; color:#a1a1a1;
      text-align:right; line-height:1.3;
    }
    .nav-user-label span { display:block; color:#cc0000; }
    .nav-avatar {
      width:24px; height:24px; background:#cc0000;
      display:flex; align-items:center; justify-content:center;
    }
    .nav-avatar svg { color:#131313; }

    /* ══════════════════════════════════════════════════════
       LAYOUT
    ══════════════════════════════════════════════════════ */
    #layout {
      position:fixed; top:44px; left:0; right:0; bottom:0; display:flex;
    }

    /* ══════════════════════════════════════════════════════
       SIDEBAR — 160px
    ══════════════════════════════════════════════════════ */
    #sidebar {
      width:160px; flex-shrink:0;
      background:#131313; border-right:1px solid #1a1a1a;
      display:flex; flex-direction:column; overflow:hidden;
    }
    /* Operator badge */
    #op-badge {
      padding:12px 14px 10px; border-bottom:1px solid #1a1a1a;
    }
    .op-label {
      font-family:'JetBrains Mono',monospace; font-size:0.55rem;
      letter-spacing:0.1em; text-transform:uppercase; color:#a1a1a1;
      display:block; margin-bottom:2px;
    }
    .op-level {
      font-family:'Space Grotesk',sans-serif; font-weight:700;
      font-size:1.5rem; color:#e5e2e1; line-height:1;
    }

    .sidebar-nav { flex:1; display:flex; flex-direction:column; padding-top:4px; }
    .nav-item {
      display:flex; align-items:center; gap:8px; padding:8px 14px;
      font-family:'JetBrains Mono',monospace; font-size:0.6rem;
      letter-spacing:0.12em; text-transform:uppercase;
      color:#a1a1a1; cursor:pointer; user-select:none;
      border:none; border-left:2px solid transparent;
      background:transparent; width:100%; text-align:left; text-decoration:none;
    }
    .nav-item:hover:not(.active) { color:#e5e2e1; background:#1a1a1a; }
    .nav-item.active { border-left-color:#cc0000; color:#cc0000; font-weight:700; }

    /* Section group divider */
    .nav-divider { height:1px; background:#1a1a1a; margin:6px 0; }

    .sidebar-spacer { flex:1; }
    .nav-item-util { color:#5e3f3a; }
    .nav-item-util:hover { color:#cc0000; background:transparent; }

    /* ══════════════════════════════════════════════════════
       MAIN AREA
    ══════════════════════════════════════════════════════ */
    #main-area {
      flex:1; display:flex; flex-direction:column; overflow:hidden; min-width:0;
    }

    /* ── Page header ─────────────────────────────────────── */
    #page-header {
      padding:12px 20px 14px; border-bottom:1px solid #1a1a1a; flex-shrink:0;
    }
    .breadcrumb-row {
      display:flex; align-items:center; gap:8px; margin-bottom:6px;
    }
    .bc-report {
      font-family:'JetBrains Mono',monospace; font-size:0.6rem;
      letter-spacing:0.12em; text-transform:uppercase; color:#cc0000;
    }
    .bc-sep { color:#3a3a3a; font-size:0.75rem; margin:0 2px; }
    .bc-repo {
      font-family:'JetBrains Mono',monospace; font-size:0.6rem;
      letter-spacing:0.06em; color:#a1a1a1;
    }
    .page-title {
      font-family:'Space Grotesk',sans-serif; font-weight:700;
      font-size:1.9rem; color:#ffb4a8; line-height:1; margin:0;
      letter-spacing:-0.02em; text-transform:uppercase;
    }

    /* ── Metadata strip ──────────────────────────────────── */
    #meta-strip {
      display:grid; grid-template-columns:repeat(4,1fr);
      border:1px solid #1a1a1a; background:#0e0e0e; flex-shrink:0;
    }
    .meta-cell {
      padding:10px 16px; border-right:1px solid #1a1a1a;
    }
    .meta-cell:last-child { border-right:none; }
    .meta-label {
      font-family:'JetBrains Mono',monospace; font-size:0.55rem;
      letter-spacing:0.1em; text-transform:uppercase; color:#a1a1a1;
      display:block; margin-bottom:4px;
    }
    .meta-value {
      font-family:'JetBrains Mono',monospace; font-weight:700;
      font-size:0.875rem; color:#e5e2e1; line-height:1;
    }
    .meta-value.accent { color:#cc0000; }

    /* ── Content area ────────────────────────────────────── */
    #content-area {
      flex:1; display:grid;
      grid-template-columns:1fr 220px;
      grid-template-rows:1fr 120px;
      overflow:hidden; min-height:0;
    }

    /* ══════════════════════════════════════════════════════
       NARRATIVE DOCUMENT — left col, scrollable
    ══════════════════════════════════════════════════════ */
    #narrative-col {
      grid-column:1; grid-row:1;
      border-right:1px solid #1a1a1a;
      overflow-y:auto; padding:0;
    }
    #narrative-col::-webkit-scrollbar { width:3px; }
    #narrative-col::-webkit-scrollbar-track { background:#131313; }
    #narrative-col::-webkit-scrollbar-thumb { background:#1a1a1a; }

    .narrative-section { padding:20px 24px 8px; }
    .narrative-section + .narrative-section { padding-top:16px; }

    .section-header {
      display:flex; align-items:center; gap:0;
      border-left:2px solid #cc0000;
      padding-left:10px; margin-bottom:14px;
    }
    .section-num {
      font-family:'JetBrains Mono',monospace; font-size:0.6rem;
      letter-spacing:0.1em; color:#5e3f3a; margin-right:8px;
    }
    .section-label {
      font-family:'JetBrains Mono',monospace; font-size:0.6rem;
      letter-spacing:0.12em; text-transform:uppercase; color:#cc0000;
    }

    .section-para {
      font-family:'Karla',sans-serif; font-size:0.875rem;
      color:#a1a1a1; line-height:1.7; margin:0 0 12px;
      max-width:680px;
    }
    .section-para:last-child { margin-bottom:0; }
    /* First words of each paragraph highlighted */
    .section-para .lead { color:#e5e2e1; }

    /* Section divider (between sections) */
    .section-sep { height:1px; background:#1a1a1a; margin:4px 24px; }

    /* ══════════════════════════════════════════════════════
       RIGHT CONTROL PANEL
    ══════════════════════════════════════════════════════ */
    #ctrl-panel {
      grid-column:2; grid-row:1;
      border-bottom:1px solid #1a1a1a;
      background:#131313; overflow-y:auto;
      display:flex; flex-direction:column;
    }
    #ctrl-panel::-webkit-scrollbar { width:3px; }
    #ctrl-panel::-webkit-scrollbar-track { background:#131313; }
    #ctrl-panel::-webkit-scrollbar-thumb { background:#1a1a1a; }

    .cp-section { padding:12px 14px; border-bottom:1px solid #1a1a1a; }
    .cp-section:last-child { border-bottom:none; }
    .cp-label {
      font-family:'JetBrains Mono',monospace; font-size:0.6rem;
      letter-spacing:0.12em; text-transform:uppercase; color:#a1a1a1;
      display:block; margin-bottom:10px;
    }

    /* Report status rows */
    .status-row {
      display:flex; align-items:center; justify-content:space-between;
      margin-bottom:8px;
    }
    .status-row:last-child { margin-bottom:0; }
    .status-key {
      font-family:'JetBrains Mono',monospace; font-size:0.6rem;
      letter-spacing:0.08em; text-transform:uppercase; color:#a1a1a1;
    }
    .status-val {
      font-family:'JetBrains Mono',monospace; font-weight:700;
      font-size:0.75rem; color:#e5e2e1;
    }
    /* Integrity bar */
    .integrity-bar-wrap { margin-top:3px; }
    .integrity-bar-track { width:100%; height:2px; background:#1a1a1a; margin-bottom:6px; }
    .integrity-bar-fill  { height:2px; background:#cc0000; }

    /* Section index */
    .index-item {
      display:flex; align-items:center; gap:8px;
      padding:6px 0; cursor:pointer;
      border-left:2px solid transparent;
    }
    .index-item:hover { border-left-color:#cc0000; padding-left:6px; }
    .index-num {
      font-family:'JetBrains Mono',monospace; font-size:0.55rem;
      color:#5e3f3a; width:16px; flex-shrink:0;
    }
    .index-name {
      font-family:'JetBrains Mono',monospace; font-size:0.55rem;
      letter-spacing:0.08em; text-transform:uppercase; color:#a1a1a1;
    }
    .index-item:hover .index-name { color:#e5e2e1; }

    /* Regenerate button */
    #regen-btn {
      width:100%; background:#cc0000; border:none;
      font-family:'JetBrains Mono',monospace; font-size:0.6rem;
      letter-spacing:0.12em; text-transform:uppercase;
      color:#fff; padding:10px 0; cursor:pointer;
      display:flex; align-items:center; justify-content:center; gap:8px;
    }
    #regen-btn:hover { background:#ff0000; }
    #regen-btn:disabled { background:#2a0000; color:#5e3f3a; cursor:not-allowed; }

    /* Export buttons */
    .export-row { display:grid; grid-template-columns:1fr 1fr; gap:6px; margin-top:8px; }
    .export-btn {
      background:transparent; border:1px solid #1a1a1a;
      font-family:'JetBrains Mono',monospace; font-size:0.55rem;
      letter-spacing:0.1em; text-transform:uppercase;
      color:#a1a1a1; padding:7px 0; cursor:pointer; text-align:center;
    }
    .export-btn:hover { border-color:#cc0000; color:#cc0000; }

    /* ══════════════════════════════════════════════════════
       GENERATION LOG — bottom full-width
    ══════════════════════════════════════════════════════ */
    #gen-log {
      grid-column:1/3; grid-row:2;
      display:flex; flex-direction:column;
      background:#0e0e0e; overflow:hidden;
    }
    #gen-log-header {
      padding:5px 14px; border-bottom:1px solid #1a1a1a;
      background:#131313; flex-shrink:0;
      display:flex; align-items:center; justify-content:space-between;
    }
    .gen-header-left {
      display:flex; align-items:center; gap:6px;
      font-family:'JetBrains Mono',monospace; font-size:0.6rem;
      letter-spacing:0.1em; text-transform:uppercase; color:#e5e2e1;
    }
    .gen-sq { width:6px; height:6px; background:#cc0000; flex-shrink:0; }
    .gen-sep { color:#5e3f3a; margin:0 2px; }
    .gen-header-right {
      font-family:'JetBrains Mono',monospace; font-size:0.55rem;
      color:#5e3f3a; letter-spacing:0.06em;
    }
    #gen-log-body {
      flex:1; overflow-y:auto; padding:6px 14px;
      display:flex; flex-direction:column;
    }
    #gen-log-body::-webkit-scrollbar { width:3px; }
    #gen-log-body::-webkit-scrollbar-track { background:#0e0e0e; }
    #gen-log-body::-webkit-scrollbar-thumb { background:#1a1a1a; }
    .g-line {
      font-family:'JetBrains Mono',monospace; font-size:0.6rem;
      line-height:1.65; white-space:nowrap; color:#a1a1a1; letter-spacing:0.04em;
    }
    .g-prefix  { color:#5e3f3a; }
    .g-tag-info  { color:#a1a1a1; }
    .g-tag-warn  { color:#cc0000; font-weight:700; }
    .g-em        { color:#e5e2e1; }
    /* Bottom-right timestamp watermark */
    #log-timestamp {
      position:absolute; bottom:6px; right:14px;
      font-family:'JetBrains Mono',monospace; font-size:0.5rem;
      color:#3a3a3a; letter-spacing:0.06em; pointer-events:none;
    }
  </style>
</head>
<body>

  <!-- ════════════════════════════════════════════════════════
       NAVBAR
  ═════════════════════════════════════════════════════════ -->
  <nav id="navbar" aria-label="System navigation">
    <div id="nav-brand">
      <a href="/" aria-label="GLYPH home">GLYPH</a>
