---
// GLYPH OS — Repository Intelligence Summary
// src/pages/repo/[id]/summary.astro

const { id } = Astro.params;

let repoOwner = 'unknown';
let repoName  = 'unknown';
try {
  const decoded = decodeURIComponent(id ?? '');
  const match   = decoded.match(/github\.com\/([^\/]+)\/([^\/\s]+)/);
  if (match) {
    repoOwner = match[1];
    repoName  = match[2].replace(/\.git$/, '');
  } else {
    const parts = decoded.split('/').filter(Boolean);
    if (parts.length >= 2) { repoOwner = parts[0]; repoName = parts[1]; }
    else if (parts.length === 1) { repoName = parts[0]; }
  }
} catch (_) {}

const repoSlug  = `${repoOwner}/${repoName}`;
const analysisId = 'REQ-99X-ALPHA-01';
const generatedDate = new Date().toISOString().split('T')[0];

// ── Static seed narrative (replaced by GET /repo/:id/summary) ──
interface NarrativeSection {
  num:   string;
  key:   string;
  label: string;
  body:  string[];
}

const sections: NarrativeSection[] = [
  {
    num:   '01',
    key:   'origin_and_intent',
    label: 'ORIGIN_AND_INTENT',
    body: [
      'Initial discovery of the core-engine repository suggests a high-stakes pivot toward decentralized node management during the late Q4 cycle. Intelligence reveals that the primary architect, known as "O-Zero", intended to bypass standard governance protocols to ensure maximum throughput in the latent environment.',
      'The underlying code structures reflect an aggressive posture toward external dependencies. Over 40% of the initial commit history was purged following the internal audit of November 12th, indicating a calculated effort to conceal the original consensus mechanism\'s origins.',
    ],
  },
  {
    num:   '02',
    key:   'architectural_evolution',
    label: 'ARCHITECTURAL_EVOLUTION',
    body: [
      'Structural analysis indicates a transition from monolithic dispatching to a highly fragmented micro-kernel approach. This evolution coincides exactly with the emergence of the "Red Border" protocol, which enforced strict isolation between critical execution threads and non-essential logging systems.',
      'During the integration phase, telemetry suggests that multiple race conditions were intentionally left unresolved as "stochastic triggers." These triggers appear to serve as an unconventional form of entropy injection, possibly for cryptographic seed generation within the kernel\'s hardened zone.',
    ],
  },
  {
    num:   '03',
    key:   'key_decisions',
    label: 'KEY_DECISIONS',
    body: [
      'Three high-confidence decision nodes emerged from the commit record. The adoption of Axum as the web framework was uncontested — a single-author commit with no debate thread. The PostgreSQL-over-SQLite choice generated the project\'s highest contention index, resolved only after a stress test revealed lock contention at scale.',
      'The BYOK credential model was the only decision unanimously ratified across all contributors. No rejection records exist for this node — a rare signal of full architectural consensus.',
    ],
  },
  {
    num:   '04',
    key:   'debate_record',
    label: 'DEBATE_RECORD',
    body: [
      'Seven debate clusters were identified across pull request threads. The most sustained conflict centered on the async runtime selection: Tokio vs async-std. The thread ran 34 comments over 11 days before benchmark data resolved the impasse in favor of Tokio.',
      'A secondary dispute over ORM selection — SQLx vs Diesel — revealed a recurring pattern: arch_priya consistently frames arguments in terms of compile-time guarantees, while dev_soren anchors on runtime maintenance cost. This divergence appears in four separate debate threads.',
    ],
  },
  {
    num:   '05',
    key:   'rejection_vault',
    label: 'REJECTION_VAULT',
    body: [
      'Five rejection records were sealed. The most significant: a full GraphQL migration layer was proposed in March and abandoned within 48 hours — no debate, direct veto from arch_priya citing schema rigidity concerns. The WebSocket realtime feed was similarly rejected, flagged as premature optimization at the current scale.',
      'The contributor scoring module (ABANDONED_FEATURE_012) remains the only rejection with an unresolved debate thread. The feature was killed for insufficient commit evidence but the underlying argument — whether automated scoring produces meaningful signal — was never formally closed.',
    ],
  },
];

const stats = { decisions: 12, debates: 7, rejections: 5 };
