        <a href="#" class="nav-item nav-item-util" aria-label="Docs">
          <svg width="9" height="9" viewBox="0 0 9 9" fill="none" aria-hidden="true" style="flex-shrink:0">
            <circle cx="4.5" cy="4.5" r="4" stroke="currentColor" stroke-width="1"/>
            <line x1="4.5" y1="4" x2="4.5" y2="7" stroke="currentColor" stroke-width="1"/>
            <circle cx="4.5" cy="2.5" r="0.5" fill="currentColor"/>
          </svg>
          DOCS
        </a>
        <a href="/" class="nav-item nav-item-util" aria-label="Logout">
          <svg width="9" height="9" viewBox="0 0 9 9" fill="none" aria-hidden="true" style="flex-shrink:0">
            <path d="M3.5 2H1V8H3.5" stroke="currentColor" stroke-width="1" fill="none"/>
            <line x1="4" y1="4.5" x2="9" y2="4.5" stroke="currentColor" stroke-width="1"/>
            <polyline points="7,3 9,4.5 7,6" stroke="currentColor" stroke-width="1" fill="none"/>
          </svg>
          LOGOUT
        </a>
      </nav>
    </aside>

    <!-- ── MAIN AREA ──────────────────────────────────────── -->
    <div id="main-area">

      <!-- Page header -->
      <header id="page-header">
        <div class="breadcrumb-row">
          <span class="bc-report">INTELLIGENCE_REPORT</span>
          <span class="bc-sep">/</span>
          <span class="bc-repo">{repoSlug}</span>
        </div>
        <h1 class="page-title">REPOSITORY INTELLIGENCE SUMMARY</h1>
      </header>

      <!-- Metadata strip -->
      <div id="meta-strip" aria-label="Report metadata">
        <div class="meta-cell" aria-label={`Analysis ID: ${analysisId}`}>
          <span class="meta-label">ANALYSIS_ID</span>
          <span class="meta-value">{analysisId}</span>
        </div>
        <div class="meta-cell" aria-label={`Decisions indexed: ${stats.decisions}`}>
          <span class="meta-label">DECISIONS_INDEXED</span>
          <span class="meta-value" id="meta-decisions">{stats.decisions}</span>
        </div>
        <div class="meta-cell" aria-label={`Debates found: ${stats.debates}`}>
          <span class="meta-label">DEBATES_FOUND</span>
          <span class="meta-value" id="meta-debates">{stats.debates}</span>
        </div>
        <div class="meta-cell" aria-label={`Rejections logged: ${stats.rejections}`}>
          <span class="meta-label">REJECTIONS_LOGGED</span>
          <span class="meta-value accent" id="meta-rejections">{String(stats.rejections).padStart(2,'0')}</span>
        </div>
      </div>

      <!-- Content area -->
      <div id="content-area">

        <!-- ── NARRATIVE DOCUMENT ─────────────────────── -->
        <article id="narrative-col" aria-label="Intelligence narrative">
          {sections.map((s, i) => (
            <>
              <div class="narrative-section" id={`section-${s.key}`}>
                <div class="section-header" aria-label={`Section ${s.num}: ${s.label}`}>
                  <span class="section-num">{s.num}</span>
                  <span class="section-label">{s.label}</span>
                </div>
                {s.body.map((para, pi) => {
                  // First two words get .lead color
                  const words   = para.split(' ');
                  const leadEnd = words.slice(0,2).join(' ');
                  const rest    = words.slice(2).join(' ');
                  return (
                    <p class="section-para">
                      <span class="lead">{leadEnd} </span>{rest}
                    </p>
                  );
                })}
              </div>
              {i < sections.length - 1 && <div class="section-sep" aria-hidden="true"></div>}
            </>
          ))}
        </article>

        <!-- ── RIGHT CONTROL PANEL ────────────────────── -->
        <aside id="ctrl-panel" aria-label="Report controls">

          <!-- Report status -->
          <div class="cp-section">
            <span class="cp-label">REPORT_STATUS</span>
            <div class="status-row" aria-label="Integrity: 98.4%">
              <span class="status-key">INTEGRITY</span>
              <span class="status-val" id="integrity-val">98.4%</span>
            </div>
            <div class="integrity-bar-wrap" aria-hidden="true">
              <div class="integrity-bar-track">
                <div class="integrity-bar-fill" style="width:98.4%"></div>
              </div>
            </div>
            <div class="status-row" aria-label="Confidence: HIGH">
              <span class="status-key">CONFIDENCE</span>
              <span class="status-val" style="color:#cc0000;">HIGH</span>
            </div>
          </div>

          <!-- Section index -->
          <div class="cp-section">
            <span class="cp-label">SECTION_INDEX</span>
            {sections.map((s) => (
              <a
                href={`#section-${s.key}`}
                class="index-item"
                aria-label={`Jump to section ${s.num}: ${s.label}`}
                onclick={`event.preventDefault(); document.getElementById('section-${s.key}')?.scrollIntoView({behavior:'instant'})`}
              >
                <span class="index-num">{s.num}</span>
                <span class="index-name">{s.label.replace(/_/g,' ')}</span>
              </a>
            ))}
          </div>

          <!-- Regenerate + export -->
          <div class="cp-section">
            <button id="regen-btn" type="button" aria-label="Regenerate intelligence summary">
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                <path d="M 8,5 A 3,3 0 1 1 5,2" stroke="currentColor" stroke-width="1" fill="none"/>
                <polyline points="5,0 5,3 8,2" stroke="currentColor" stroke-width="1" fill="none"/>
              </svg>
              REGENERATE_SUMMARY
            </button>
            <div class="export-row">
              <button class="export-btn" type="button" id="export-pdf-btn" aria-label="Export as PDF">EXPORT_PDF</button>
              <button class="export-btn" type="button" id="export-json-btn" aria-label="Export as raw JSON">RAW_JSON</button>
            </div>
          </div>

        </aside>

        <!-- ── GENERATION LOG ─────────────────────────── -->
        <section id="gen-log" style="position:relative;" aria-label="Generation log">
          <div id="gen-log-header">
            <div class="gen-header-left">
              <span class="gen-sq" aria-hidden="true"></span>
              GENERATION_LOG
              <span class="gen-sep">//</span>
              NIM_STDOUT
            </div>
            <span class="gen-header-right">MODEL: llama-3.1-nemotron-70b</span>
          </div>
          <div id="gen-log-body" role="log" aria-label="NIM generation log" aria-live="polite">
            <!-- Seed lines matching screenshot -->
            <div class="g-line"><span class="g-prefix">&gt; </span><span class="g-tag-info">[INFO] FETCHING_REPOSITORY_METADATA ... 200 OK</span></div>
            <div class="g-line"><span class="g-prefix">&gt; </span><span class="g-tag-warn">[WARN] ANOMALOUS_COMMIT_PATTERN DETECTED in branch <span class="g-em">'master'</span></span></div>
            <div class="g-line"><span class="g-prefix">&gt; </span><span class="g-tag-info">[INFO] ASSEMBLING_INTEL_PACKAGE_ALPHA... <span class="g-em">COMPLETE</span></span></div>
          </div>
          <span id="log-timestamp" aria-hidden="true">TERMINAL_FEED: 00:17:04</span>
        </section>

      </div><!-- /content-area -->
    </div><!-- /main-area -->
  </div><!-- /layout -->

  <!-- ════════════════════════════════════════════════════════
       SCRIPTS
  ═════════════════════════════════════════════════════════ -->
  <script define:vars={{ seedSections: sections, repoStats: stats }}>
    const API_BASE = (window as any).__GLYPH_API__ ?? (import.meta as any).env?.PUBLIC_API_BASE_URL ?? 'http://localhost:8000';

    // ── Timestamp watermark ───────────────────────────────
    (function initTimestamp() {
      const el = document.getElementById('log-timestamp');
      if (!el) return;
      function tick() {
        const d = new Date();
        const h = String(d.getHours()).padStart(2,'0');
        const m = String(d.getMinutes()).padStart(2,'0');
        const s = String(d.getSeconds()).padStart(2,'0');
        el.textContent = `TERMINAL_FEED: ${h}:${m}:${s}`;
        setTimeout(tick, 1000);
      }
      tick();
    })();

    // ── Live generation log ───────────────────────────────
    (function initGenLog() {
      const body = document.getElementById('gen-log-body');
      if (!body) return;

      const pool = [
        () => `<span class="g-prefix">&gt; </span><span class="g-tag-info">[NIM] Prompt tokens: <span class="g-em">${Math.floor(Math.random()*500+2800)}</span> — context window: 128k</span>`,
        () => `<span class="g-prefix">&gt; </span><span class="g-tag-info">[NIM] Sampling temperature: 0.3 — max_tokens: 2048</span>`,
        () => `<span class="g-prefix">&gt; </span><span class="g-tag-info">[PARSE] Section 01 // ORIGIN_AND_INTENT — <span class="g-em">extracted</span></span>`,
        () => `<span class="g-prefix">&gt; </span><span class="g-tag-info">[PARSE] Section 02 // ARCHITECTURAL_EVOLUTION — <span class="g-em">extracted</span></span>`,
        () => `<span class="g-prefix">&gt; </span><span class="g-tag-info">[PARSE] Section 03 // KEY_DECISIONS — <span class="g-em">${repoStats.decisions} nodes identified</span></span>`,
        () => `<span class="g-prefix">&gt; </span><span class="g-tag-info">[PARSE] Section 04 // DEBATE_RECORD — <span class="g-em">${repoStats.debates} threads resolved</span></span>`,
        () => `<span class="g-prefix">&gt; </span><span class="g-tag-info">[PARSE] Section 05 // REJECTION_VAULT — <span class="g-em">${repoStats.rejections} records sealed</span></span>`,
        () => `<span class="g-prefix">&gt; </span><span class="g-tag-warn">[WARN] ANOMALOUS_COMMIT_PATTERN DETECTED in branch <span class="g-em">'master'</span></span>`,
        () => `<span class="g-prefix">&gt; </span><span class="g-tag-info">[NIM] Response complete — confidence: <span class="g-em">98.4%</span></span>`,
        () => `<span class="g-prefix">&gt; </span><span class="g-tag-info">[SYSTEM] Narrative written to report store</span>`,
        () => `<span class="g-prefix">&gt; </span><span class="g-tag-info">[INFO] ASSEMBLING_INTEL_PACKAGE_ALPHA... <span class="g-em">COMPLETE</span></span>`,
      ];
      let idx = 0;
      setInterval(() => {
        const line = document.createElement('div');
        line.className = 'g-line';
        line.innerHTML = pool[idx % pool.length]();
        idx++;
        body.appendChild(line);
        body.scrollTop = body.scrollHeight;
        while (body.children.length > 30) body.removeChild(body.firstChild);
      }, 3000);
    })();

    // ── Hydrate from real API ─────────────────────────────
    (function hydrateNarrative() {
      const pathParts = window.location.pathname.split('/').filter(Boolean);
      const jobId     = pathParts[1] ?? '';
      const uuidRe    = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
      if (!uuidRe.test(jobId)) return;

      const nimKey = sessionStorage.getItem('glyph_nim_key') ?? '';
      if (!nimKey) return;

      fetch(`${API_BASE}/api/repo/${jobId}/summary`, {
        headers: { 'X-Nim-Api-Key': nimKey },
      })
        .then(r => r.ok ? r.json() : null)
        .then(data => {
          if (!data?.narrative) return;
          // Split narrative into paragraphs and distribute into sections
          const paras = data.narrative
            .split(/\n\n+/)
            .map(p => p.trim())
            .filter(Boolean);

          const col = document.getElementById('narrative-col');
          if (!col) return;
          col.innerHTML = '';

          const sectionLabels = [
            '01 // ORIGIN_AND_INTENT',
            '02 // ARCHITECTURAL_EVOLUTION',
            '03 // KEY_DECISIONS',
            '04 // DEBATE_RECORD',
            '05 // REJECTION_VAULT',
          ];

          const perSection = Math.ceil(paras.length / 5);
          sectionLabels.forEach((lbl, si) => {
            const chunk = paras.slice(si * perSection, (si + 1) * perSection);
            if (!chunk.length) return;

            const sec = document.createElement('div');
            sec.className = 'narrative-section';
            sec.id        = `section-s${si}`;

            const hdr = document.createElement('div');
            hdr.className = 'section-header';
            hdr.innerHTML = `<span class="section-num">${String(si+1).padStart(2,'0')}</span><span class="section-label">${lbl.split(' // ')[1]}</span>`;
            sec.appendChild(hdr);

            chunk.forEach(para => {
              const p     = document.createElement('p');
              p.className = 'section-para';
              const words = para.split(' ');
              p.innerHTML = `<span class="lead">${words.slice(0,2).join(' ')} </span>${words.slice(2).join(' ')}`;
              sec.appendChild(p);
            });

            col.appendChild(sec);
            if (si < 4) {
              const sep = document.createElement('div');
              sep.className = 'section-sep';
              col.appendChild(sep);
            }
          });

          // Update meta stats
          if (data.node_count) {
            const md = document.getElementById('meta-decisions');
            if (md) md.textContent = String(data.node_count);
          }
        })
        .catch(() => {});
    })();

    // ── Regenerate button ─────────────────────────────────
    (function initRegen() {
      const btn = document.getElementById('regen-btn');
      if (!btn) return;
      btn.addEventListener('click', async () => {
        const pathParts = window.location.pathname.split('/').filter(Boolean);
        const jobId     = pathParts[1] ?? '';
        const uuidRe    = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
        const nimKey    = sessionStorage.getItem('glyph_nim_key') ?? '';

        if (!uuidRe.test(jobId) || !nimKey) {
          btn.textContent = 'NIM_KEY_REQUIRED';
          setTimeout(() => { btn.innerHTML = '<svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M 8,5 A 3,3 0 1 1 5,2" stroke="currentColor" stroke-width="1" fill="none"/><polyline points="5,0 5,3 8,2" stroke="currentColor" stroke-width="1" fill="none"/></svg> REGENERATE_SUMMARY'; }, 2000);
          return;
        }

        btn.textContent = 'GENERATING...';
        (btn as HTMLButtonElement).disabled = true;

        try {
          const resp = await fetch(`${API_BASE}/api/repo/${jobId}/summary`, {
            headers: { 'X-Nim-Api-Key': nimKey },
          });
          if (resp.ok) {
            window.location.reload();
          } else {
            btn.textContent = 'FAILED — RETRY';
          }
        } catch {
          btn.textContent = 'ERROR';
        } finally {
          (btn as HTMLButtonElement).disabled = false;
          setTimeout(() => { btn.innerHTML = '<svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M 8,5 A 3,3 0 1 1 5,2" stroke="currentColor" stroke-width="1" fill="none"/><polyline points="5,0 5,3 8,2" stroke="currentColor" stroke-width="1" fill="none"/></svg> REGENERATE_SUMMARY'; }, 3000);
        }
      });
    })();

    // ── Export buttons ────────────────────────────────────
    (function initExport() {
      document.getElementById('export-json-btn')?.addEventListener('click', () => {
        const narrative = document.getElementById('narrative-col')?.innerText ?? '';
        const blob = new Blob([JSON.stringify({ narrative, generated: new Date().toISOString() }, null, 2)], { type: 'application/json' });
        const a = document.createElement('a'); a.href = URL.createObjectURL(blob);
        a.download = 'glyph-summary.json'; a.click();
      });
      document.getElementById('export-pdf-btn')?.addEventListener('click', () => {
        window.print();
      });
    })();
  </script>

</body>
</html>
