  <!-- ════════════════════════════════════════════════════════
       LAYOUT
  ═════════════════════════════════════════════════════════ -->
  <div id="layout">

    <!-- ── SIDEBAR ───────────────────────────────────────── -->
    <aside id="sidebar" aria-label="Navigation">
      <div id="op-badge">
        <span class="op-label">OPERATOR_LVL</span>
