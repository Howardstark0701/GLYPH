    </aside>

    <!-- ── MAIN AREA ─────────────────────────────────────── -->
    <div id="main-area">

      <!-- Page header -->
      <header id="page-header">
        <div>
          <h1 class="page-title">DEBATE_EXPLORER.V4</h1>
          <p class="thread-id">
            THREAD_ID: PR_{debateThread.prNumber}_{debateThread.topic}
            <span style="margin: 0 8px; color: #262626;">//</span>
            STATUS: <span class="thread-status" style={`color: ${statusColor}`}>{debateThread.status}</span>
          </p>
        </div>
        <div class="header-stats" aria-label="Analysis metrics">
          <div class="stat-block" aria-label="Throttle level: 98.4 percent">
            <span class="stat-label">THROTTLE_LEVEL</span>
            <span class="stat-value">98.4%</span>
          </div>
          <div class="stat-block" aria-label="Risk index: Critical">
            <span class="stat-label">RISK_INDEX</span>
            <span class="stat-value critical">CRITICAL</span>
          </div>
        </div>
      </header>

      <!-- Content grid -->
      <div id="content-grid">

        <!-- ── SENTIMENT SPECTRUM ──────────────────────── -->
        <section id="sentiment-panel" aria-labelledby="sentiment-label">
          <div class="panel-header">
            <span class="ph-left" id="sentiment-label">SENTIMENT_SPECTRUM</span>
            <span class="ph-right">WINDOW: 128H</span>
          </div>
          <div id="sentiment-chart-wrap">
            <svg id="sentiment-svg" aria-label="Sentiment activity bar chart" role="img"></svg>
          </div>
          <div id="sentiment-metrics">
            <div class="sm-col" aria-label={`Agreement: ${sentimentMetrics.agreement}%`}>
              <div class="sm-label">AGREEMENT</div>
              <div class="sm-value">{sentimentMetrics.agreement}%</div>
            </div>
            <div class="sm-col" aria-label={`Contention: ${sentimentMetrics.contention}%`}>
              <div class="sm-label">CONTENTION</div>
              <div class="sm-value">{sentimentMetrics.contention}%</div>
            </div>
            <div class="sm-col" aria-label={`Redundancy: ${sentimentMetrics.redundancy}%`}>
              <div class="sm-label">REDUNDANCY</div>
              <div class="sm-value">{sentimentMetrics.redundancy}%</div>
            </div>
            <div class="sm-col" aria-label={`Unresolved: ${sentimentMetrics.unresolved}%`}>
              <div class="sm-label">UNRESOLVED</div>
              <div class="sm-value">{sentimentMetrics.unresolved}%</div>
            </div>
          </div>
        </section>

        <!-- ── INTERACTION DENSITY ────────────────────── -->
        <aside id="density-panel" aria-labelledby="density-label">
          <div class="panel-header">
            <span class="ph-left" id="density-label">INTERACTION_DENSITY</span>
          </div>
          <div id="heatmap-grid" aria-label="Contributor interaction heatmap" role="img">
            {heatValues.map((row, ri) => (
              <div class="hm-row">
                {row.map((val, ci) => {
                  // Threshold-based fill: >0.55 → red, else dark grey
                  const bg = val > 0.55 ? '#cc0000' : val > 0.3 ? '#2a2a2a' : '#1a1a1a';
                  const opacity = val > 0.55 ? (0.4 + val * 0.6).toFixed(2) : '1';
                  return (
                    <div
                      class="hm-cell"
                      style={`background:${bg};opacity:${opacity};`}
                      aria-hidden="true"
                    ></div>
                  );
                })}
              </div>
            ))}
          </div>
          <div id="density-stats">
            <div class="ds-row" aria-label={`Total comments: ${heatmapStats.totalComments}`}>
              <span class="ds-label">TOTAL_COMMENTS:</span>
              <span class="ds-value">{heatmapStats.totalComments}</span>
            </div>
            <div class="ds-row" aria-label={`Average depth: ${heatmapStats.averageDepth}`}>
              <span class="ds-label">AVERAGE_DEPTH:</span>
              <span class="ds-value">{heatmapStats.averageDepth}</span>
            </div>
          </div>
        </aside>

        <!-- ── KEY ACTOR PROFILES ──────────────────────── -->
        <section id="profiles-row" aria-labelledby="profiles-label">
          <div id="profiles-header">
            <span class="profiles-label" id="profiles-label">KEY_ACTOR_PROFILES</span>
          </div>
          <div id="profiles-cards" role="list" aria-label="Key contributor profiles">
            {contributors.map((c) => {
              const initials = c.handle.split('_').map(w => w[0]).join('').toUpperCase().slice(0, 2);
              return (
                <div class="profile-card" role="listitem" aria-label={`Contributor: ${c.handle}`}>
                  <div class="profile-top">
                    <div class="profile-avatar" aria-hidden="true">
                      <span class="profile-avatar-initials">{initials}</span>
                    </div>
                    <div class="profile-info">
                      <span class="profile-handle">{c.handle}</span>
                      <span class="profile-role-chip" role="status">{c.role}</span>
                    </div>
                  </div>
                  <div class="profile-metric" aria-label={`${c.metric.label}: ${c.metric.pct}%`}>
                    <div class="metric-header-row">
                      <span class="metric-lbl">{c.metric.label}</span>
                      <span class="metric-pct">{c.metric.pct}%</span>
                    </div>
                    <div class="metric-track" aria-hidden="true">
                      <div class="metric-fill" style={`width:${c.metric.pct}%`}></div>
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        </section>

        <!-- ── LIVE ANALYSIS FEED ──────────────────────── -->
        <section id="feed-panel" aria-labelledby="feed-title">
          <div id="feed-header">
            <span class="feed-live-sq" aria-hidden="true"></span>
            <span class="feed-title" id="feed-title">LIVE_ANALYSIS_FEED</span>
            <span style="margin-left:auto;font-family:'JetBrains Mono',monospace;font-size:0.55rem;color:#a1a1a1;letter-spacing:0.06em;">BAUDRATE: 115200</span>
          </div>
          <div id="feed-body" role="log" aria-label="Live analysis feed" aria-live="polite">
            <div class="feed-line">
              <span class="f-ts">[14:22:01]</span>
              <span class="f-info"> INFO: Scanning thread PR_<span class="f-em">{debateThread.prNumber}</span>...</span>
            </div>
            <div class="feed-line">
              <span class="f-ts">[14:22:03]</span>
              <span class="f-alert"> ALERT: High-frequency interaction detected between </span>
              <span class="f-em">'{contributors[0].handle}'</span><span class="f-info"> and </span><span class="f-em">'{contributors[1].handle}'</span><span class="f-info">.</span>
            </div>
            <div class="feed-line">
              <span class="f-ts">[14:22:05]</span>
              <span class="f-info"> ANALYSIS: Conflict centered on </span><span class="f-em">AUTH_REDESIGN</span><span class="f-info"> in core module.</span>
            </div>
            <div class="feed-line" style="font-weight:700;">
              <span class="f-ts">[14:22:08]</span>
              <span class="f-alert"> DATA: Hostility index rising: </span><span class="f-em">+12.4%</span><span class="f-info"> in last 10 minutes.</span>
            </div>
            <div class="feed-line" style="color:#cc0000;font-weight:700;">
              <span class="f-ts">[14:22:12]</span>
              <span> CRITICAL: Logical recursion detected in </span><span class="f-em">'{contributors[1].handle}'</span><span> argument. Conflict resolution recommended.</span>
            </div>
            <div class="feed-line" style="opacity:0.5;">
              <span class="f-ts">[14:22:15]</span>
              <span class="f-info"> INFO: Mapping user metadata clusters...</span>
            </div>
            <div class="feed-line f-pulse">
              <span class="f-ts">[14:22:18]</span>
              <span class="f-info"> SYS: Listening for incoming buffer_overflow_warnings..._</span>
            </div>
          </div>
        </section>

      </div><!-- /content-grid -->
    </div><!-- /main-area -->
  </div><!-- /layout -->

  <!-- ════════════════════════════════════════════════════════
       SCRIPTS
  ═════════════════════════════════════════════════════════ -->
  <script define:vars={{ sentimentBars, prNumber: debateThread.prNumber, contributors }}>
    const API_BASE = (window as any).__GLYPH_API__ ?? (import.meta as any).env?.PUBLIC_API_BASE_URL ?? 'http://localhost:8000';
    // ── Execute fetch ─────────────────────────────────────
    (function() {
      const btn = document.getElementById('execute-fetch');
      if (!btn) return;
      btn.addEventListener('click', () => {
        btn.textContent = 'FETCHING...';
        setTimeout(() => { btn.textContent = 'EXECUTE_FETCH'; }, 2000);
      });
    })();

    // ── Hydrate metrics from real API ─────────────────────
    (function hydrateDebates() {
      const pathParts = window.location.pathname.split('/').filter(Boolean);
      const jobId     = pathParts[1] ?? '';
      const uuidRe    = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
      if (!uuidRe.test(jobId)) return;

      fetch(`${API_BASE}/api/repo/${jobId}/debates`)
        .then(r => r.ok ? r.json() : null)
        .then(data => {
          if (!data?.metrics) return;
          const m = data.metrics;
          const cols = document.querySelectorAll('.sm-value');
          if (cols[0]) cols[0].textContent = `${m.agreement_pct ?? 18}%`;
          if (cols[1]) cols[1].textContent = `${m.contention_pct ?? 54}%`;
        })
        .catch(() => {});
    })();

    // ── Live analysis feed ────────────────────────────────
    (function initFeed() {
      const body = document.getElementById('feed-body');
      if (!body) return;

      function nowTs() {
        const d = new Date();
        const h = String(d.getHours()).padStart(2, '0');
        const m = String(d.getMinutes()).padStart(2, '0');
        const s = String(d.getSeconds()).padStart(2, '0');
        return `[${h}:${m}:${s}]`;
      }

      const handles = contributors.map(c => c.handle);
      const shas    = ['0xf3a91c2', '0xa9e3f14', '0x2c4d801', '0x7b1c339', '0x1d5a0c8'];
      const topics  = ['AUTH_REDESIGN', 'DB_SCHEMA_V3', 'API_GATEWAY', 'NIM_PIPELINE', 'INGESTION_LAYER'];
      let   decIdx  = 7;
      let   ri = 0, si = 0, ti = 0;

      type Level = 'INFO' | 'ALERT' | 'ANALYSIS' | 'DATA' | 'LOG' | 'CRITICAL';

      const pool: Array<() => { level: Level; body: string }> = [
        () => ({ level: 'INFO',     body: `Scanning PR thread <span class="f-em">#${prNumber + ri++}</span>...` }),
        () => ({ level: 'ALERT',    body: `High-frequency interaction: <span class="f-em">'${handles[0]}'</span> and <span class="f-em">'${handles[1]}'</span>.` }),
        () => ({ level: 'ANALYSIS', body: `Debate centered on <span class="f-em">${topics[ti++ % topics.length]}</span> in commit <span class="f-em">${shas[si++ % shas.length]}</span>.` }),
        () => ({ level: 'DATA',     body: `Contention index rising: <span class="f-em">+${Math.floor(Math.random()*12+2)}%</span> in last 10 minutes.` }),
        () => ({ level: 'INFO',     body: `Generating intent node for <span class="f-em">decision_id: #ARCHITECTURAL_DECISION_${String(decIdx++).padStart(3,'0')}</span>...` }),
        () => ({ level: 'CRITICAL', body: `Position conflict in <span class="f-em">'${handles[1]}'</span> argument. Dismissive tone flagged.` }),
        () => ({ level: 'LOG',      body: `Buffer synchronized. Waiting for next payload...` }),
        () => ({ level: 'DATA',     body: `NIM response latency: <span class="f-em">${Math.floor(Math.random()*80+120)}ms</span>.` }),
        () => ({ level: 'INFO',     body: `Extracting contributor reasoning: <span class="f-em">${handles[ri % handles.length]}</span>.` }),
        () => ({ level: 'ANALYSIS', body: `Rejection candidate flagged: <span class="f-em">ABANDONED_FEATURE_0${String(Math.floor(Math.random()*20)+1).padStart(2,'0')}</span>.` }),
      ];

      let poolIdx = 0;
      const cls: Record<Level, string> = {
        INFO: 'f-info', ALERT: 'f-alert', ANALYSIS: 'f-info',
        DATA: 'f-info', LOG: 'f-info', CRITICAL: 'f-critical',
      };

      setInterval(() => {
        const entry = pool[poolIdx % pool.length]();
        poolIdx++;
        const line = document.createElement('div');
        line.className = 'feed-line';
        line.innerHTML = `<span class="f-ts">${nowTs()}</span><span class="${cls[entry.level]}"> ${entry.level}: </span><span class="f-body">${entry.body}</span>`;
        body.appendChild(line);
        body.scrollTop = body.scrollHeight;
        while (body.children.length > 40) { body.removeChild(body.firstChild); }
      }, 2000);
    })();
  </script>

  <!-- ── D3 Sentiment bar chart ─────────────────────────── -->
  <script type="module" define:vars={{ sentimentBars }}>
    import * as d3 from 'https://cdn.jsdelivr.net/npm/d3@7/+esm';

    const wrap = document.getElementById('sentiment-chart-wrap');
    if (!wrap) throw new Error();

    const W   = wrap.offsetWidth  || 400;
    const H   = wrap.offsetHeight || 120;
    const PAD = { top: 10, right: 4, bottom: 4, left: 4 };

    const svg = d3.select('#sentiment-svg')
      .attr('viewBox', `0 0 ${W} ${H}`)
      .attr('preserveAspectRatio', 'none');

    const data   = sentimentBars;
    const maxVal = d3.max(data) ?? 1;

    const x = d3.scaleBand()
      .domain(data.map((_, i) => String(i)))
      .range([PAD.left, W - PAD.right])
      .padding(0.25);

    const y = d3.scaleLinear()
      .domain([0, maxVal])
      .range([H - PAD.bottom, PAD.top]);

    // Dotted horizontal gridlines only — 4 levels
    const gridVals = [0.25, 0.5, 0.75, 1.0].map(f => f * maxVal);
    svg.append('g').selectAll('line')
      .data(gridVals)
      .enter()
      .append('line')
      .attr('x1', PAD.left)
      .attr('x2', W - PAD.right)
      .attr('y1', d => y(d))
      .attr('y2', d => y(d))
      .attr('stroke', '#262626')
      .attr('stroke-width', 1)
      .attr('stroke-dasharray', '3 3');

    // Bars — filled #cc0000, no radius
    svg.append('g').selectAll('rect')
      .data(data)
      .enter()
      .append('rect')
      .attr('x',      (_, i) => x(String(i)) ?? 0)
      .attr('y',      d => y(d))
      .attr('width',  x.bandwidth())
      .attr('height', d => H - PAD.bottom - y(d))
      .attr('fill',   '#cc0000');
  </script>

  <!-- Bottom status bar -->
  <div id="status-bar" aria-label="System status">
    <div class="sb-left">
      <span class="sb-item">MEM: 12.4GB/32GB</span>
      <span class="sb-item">CPU: 44%</span>
    </div>
    <div class="sb-right">
      <span class="sb-item accent">ENCRYPTION: AES-256-GCM</span>
    </div>
  </div>

</body>
